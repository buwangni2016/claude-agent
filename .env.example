# ── Project 1: Vercel Claude Bot (root directory) ──────────────
# Claude API
ANTHROPIC_API_KEY=your_api_key_here
ANTHROPIC_BASE_URL=https://your-claude-proxy.com
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Telegram webhook (via Maton API Gateway)
MATON_API_KEY=your_maton_api_key_here
TELEGRAM_CONNECTION_ID=your_telegram_connection_id_here

# ── Project 2: Telegram Claude Bot (telegram-claude-bot/) ───────
# See telegram-claude-bot/.env.example
# Requires: TELEGRAM_BOT_TOKEN + claude CLI installed
